      "cell_type": "code",
      "source": [
        "n1 = float(input(\"Digite o primeiro número: \"))\n",
        "n2 = float(input(\"Digite o segundo número: \"))\n",
        "op = input(\"insira a operação:\")\n",
        "if op == \"+\":\n",
        "        print(n1, op, n2, \"=\", n1 + n2)\n",
        "elif op == \"-\":\n",
        "        print(n1, op, n2, \"=\", n1 - n2)\n",
        "elif op == \"*\":\n",
        "        print(n1, op, n2, \"=\", n1 * n2)\n",
        "elif op == \"/\":\n",
        "        print(n1, op, n2, \"=\", n1 / n2)\n",
        "else:\n",
        "        print(\"Operação inválida\")"
      ],
